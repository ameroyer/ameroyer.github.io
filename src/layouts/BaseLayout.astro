---
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  accentColor?: 'home' | 'cv' | 'pub' | 'port' | 'notes';
  image?: string;
}

const {
  title = "Amélie Royer",
  description = "Research Scientist at Kyutai Labs. Working on machine learning, computer vision, and AI.",
  accentColor = 'home',
  image = '/images/profile.png',
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const fullTitle = title === "Amélie Royer" ? title : `${title} — Amélie Royer`;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <meta name="author" content="Amélie Royer" />
  <base href="/" />

  <!-- Canonical -->
  <link rel="canonical" href={canonicalURL} />

  <!-- Open Graph -->
  <meta property="og:type" content="website" />
  <meta property="og:url" content={canonicalURL} />
  <meta property="og:title" content={fullTitle} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={new URL(image, Astro.site)} />

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary" />
  <meta name="twitter:site" content="@royaleerieme" />
  <meta name="twitter:title" content={fullTitle} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={new URL(image, Astro.site)} />

  <!-- Favicon -->
  <link rel="icon" type="image/png" href="/images/github_avatar.png" />

  <!-- KaTeX CSS for math rendering -->
  <link
    rel="stylesheet"
    href="https://cdn.jsdelivr.net/npm/katex@0.16.9/dist/katex.min.css"
    integrity="sha384-n8MVd4RsNIU0tAv4ct0nTaAbDJwPJzDEaqSD1odI+WdtXRGWt2kTvGFasHpSy3SV"
    crossorigin="anonymous"
  />

  <title>{fullTitle}</title>

  <!-- Protect navigation from page-specific stylesheets (e.g. idyll_styles.css on the Polya page) -->
  <style is:global>
    #site-header button { display: inline-flex !important; margin: 0 !important; }
    #site-header svg { overflow: visible !important; }
  </style>

  <!-- Prevent flash of wrong theme -->
  <script is:inline>
    (function() {
      var t = localStorage.getItem('theme');
      if (t === 'light') document.documentElement.classList.add('light');
    })();
  </script>
</head>
<body>
  <Navigation />

  <main class="pt-16 min-h-screen">
    <slot />
  </main>

  <Footer />

  <!-- Scroll reveal IntersectionObserver -->
  <script>
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((e) => {
          if (e.isIntersecting) {
            e.target.classList.add('visible');
          }
        });
      },
      { threshold: 0.1 }
    );
    document.querySelectorAll('.reveal').forEach((el) => observer.observe(el));
  </script>
</body>
</html>
