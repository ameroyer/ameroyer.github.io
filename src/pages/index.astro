---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeader from '../components/SectionHeader.astro';
import PublicationCard from '../components/PublicationCard.astro';
import { getCollection } from 'astro:content';

const allPublications = await getCollection('publications');
const selectedPubs = allPublications
  .filter((p) => p.data.selected)
  .sort((a, b) => b.data.year - a.data.year);
---

<BaseLayout
  title="Amélie Royer"
  description="Research Scientist at Kyutai Labs, Paris. Working on machine learning, computer vision, and AI efficiency."
  accentColor="home"
>

  <!-- ── Profile intro ─────────────────────────────────── -->
  <section class="max-w-5xl mx-auto px-6 pt-14 pb-14">
    <div class="flex flex-col sm:flex-row gap-10 sm:gap-14 items-start reveal">

      <!-- Left: photo + location + social -->
      <div class="flex flex-col items-center gap-4 reveal reveal-delay-1" style="min-width: 172px;">

        <!-- Spinning rainbow ring with sparkles -->
        <div class="profile-wrap">
          <div class="profile-ring-outer">
            <div class="profile-ring-inner">
              <img id="profile-photo" src="/images/profile.png" alt="Amélie Royer" title="psst... try double-clicking 🪄" />
            </div>
          </div>
          <!-- Sparkle stars -->
          <div class="sparkle s1"></div>
          <div class="sparkle s2"></div>
          <div class="sparkle s3"></div>
          <div class="sparkle s4"></div>
          <div class="sparkle s5"></div>
          <div class="sparkle s6"></div>
        </div>

        <!-- Location -->
        <p class="text-sm text-center" style="color: #9e99b0;">
          🥐 Paris, France
        </p>

        <!-- Social links — stacked vertically like old sidebar -->
        <div class="flex flex-col items-center gap-1.5">
          <a href="https://github.com/ameroyer" target="_blank" rel="noopener"
             class="flex items-center gap-2 text-xs font-medium transition-opacity hover:opacity-60"
             style="color: #b8b4cc;">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
            ameroyer
          </a>
          <a href="https://www.linkedin.com/in/am%C3%A9lie-royer-aa4582168/" target="_blank" rel="noopener"
             class="flex items-center gap-2 text-xs font-medium transition-opacity hover:opacity-60"
             style="color: #b8b4cc;">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
            LinkedIn
          </a>
          <a href="https://scholar.google.com/citations?user=P9-oT8AAAAAJ" target="_blank" rel="noopener"
             class="flex items-center gap-2 text-xs font-medium transition-opacity hover:opacity-60"
             style="color: #b8b4cc;">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor"><path d="M12 24a7 7 0 1 1 0-14 7 7 0 0 1 0 14zm0-24L0 9.5l4.838 3.94A8 8 0 0 1 12 9a8 8 0 0 1 7.162 4.44L24 9.5z"/></svg>
            Google Scholar
          </a>
          <a href="https://twitter.com/royaleerieme" target="_blank" rel="noopener"
             class="flex items-center gap-2 text-xs font-medium transition-opacity hover:opacity-60"
             style="color: #b8b4cc;">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
            @royaleerieme
          </a>
          <a href="mailto:amelie@kyutai.org"
             class="flex items-center gap-2 text-xs font-medium transition-opacity hover:opacity-60"
             style="color: #b8b4cc;">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
            amelie@kyutai.org
          </a>
        </div>
      </div>

      <!-- Right: bio + current role + quick links -->
      <div class="flex-1 reveal reveal-delay-2">

        <!-- Name + title -->
        <h1 class="text-2xl font-bold mb-0.5" style="color: #ede9f8;">Amélie Royer</h1>
        <p class="text-sm mb-5" style="color: #9e99b0;">
          Research Scientist ·
          <a href="https://kyutai.org/" target="_blank" rel="noopener"
             class="transition-opacity hover:opacity-70" style="color: #7ec8f0;">Kyutai Labs</a>
        </p>

        <!-- Bio -->
        <div style="color: #cdc8e0; line-height: 1.78; font-size: 0.96rem;">
          <p class="mb-3">
            I'm a Research Scientist at
            <a href="https://kyutai.org/" target="_blank" rel="noopener"
               class="font-medium hover:underline" style="color: #7ec8f0;">Kyutai Labs</a>,
            a new AI lab committed to Open Science, based in Paris, France. 
            My research interests are multimodal learning, computer vision, and neural network efficiency
          </p>
          <p class="mb-3">
            Prior to this, I was a Deep Learning Research Engineer at Qualcomm AI Research (2021–2024),
            working on neural network efficiency via conditional compute and dynamic sparsity.
            I graduated with a PhD from IST Austria in 2020, working on Machine Learning and Computer Vision,
            and hold a Masters in CS from École normale supérieure de Rennes (2015).
          </p>
        </div>

        <!-- Quick nav pills -->
        <div class="flex flex-wrap gap-2 mt-6">
          <a href="/publications" class="tag tag-pub px-4 py-2 rounded-lg text-xs font-semibold transition-opacity hover:opacity-75">Publications →</a>
          <a href="/portfolio"    class="tag tag-port px-4 py-2 rounded-lg text-xs font-semibold transition-opacity hover:opacity-75">Portfolio →</a>
          <a href="/notes"        class="tag tag-notes px-4 py-2 rounded-lg text-xs font-semibold transition-opacity hover:opacity-75">Reading Notes →</a>
          <a href="/cv"           class="tag tag-cv px-4 py-2 rounded-lg text-xs font-semibold transition-opacity hover:opacity-75">CV →</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ── Selected Publications ────────────────────────── -->
  {selectedPubs.length > 0 && (
    <section class="max-w-5xl mx-auto px-6 pb-24">
      <div class="mb-8" style="height: 1px; background: rgba(0,0,0,0.09);"></div>
      <div class="reveal">
        <SectionHeader title="Selected Publications" color="pub" icon="📄" />
      </div>
      <div class="flex flex-col gap-4 mt-6">
        {selectedPubs.map((pub, i) => (
          <div class={`reveal reveal-delay-${Math.min(i + 1, 5)}`}>
            <PublicationCard
              title={pub.data.title}
              authors={pub.data.authors}
              venue={pub.data.venue}
              year={pub.data.year}
              selected={pub.data.selected}
              paperurl={pub.data.paperurl}
              slides={pub.data.slides}
              poster={pub.data.poster}
              code={pub.data.code}
              demo={pub.data.demo}
              teaser={pub.data.teaser}
              slug={pub.slug}
            />
          </div>
        ))}
      </div>
      <div class="mt-6 reveal">
        <a href="/publications" class="text-sm font-medium transition-opacity hover:opacity-70"
           style="color: #ffaa44;">
          View all publications →
        </a>
      </div>
    </section>
  )}

</BaseLayout>

<style>
  @keyframes coin-flip-to-back {
    0%   { transform: perspective(600px) rotateY(0deg); }
    50%  { transform: perspective(600px) rotateY(90deg); }
    100% { transform: perspective(600px) rotateY(0deg); }
  }
  @keyframes coin-flip-to-front {
    0%   { transform: perspective(600px) rotateY(0deg); }
    50%  { transform: perspective(600px) rotateY(-90deg); }
    100% { transform: perspective(600px) rotateY(0deg); }
  }
  #profile-photo.flipping-out {
    animation: coin-flip-to-back 0.35s ease-in-out forwards;
  }
  #profile-photo.flipping-in {
    animation: coin-flip-to-front 0.35s ease-in-out forwards;
  }
  #profile-photo {
    cursor: pointer;
  }
</style>

<script>
  const img = document.getElementById('profile-photo') as HTMLImageElement | null;
  if (img) {
    const photos = ['/images/profile.png', '/images/github_avatar.png'];
    let current = 0;

    img.addEventListener('dblclick', () => {
      img.classList.remove('flipping-in', 'flipping-out');
      img.classList.add('flipping-out');

      setTimeout(() => {
        current = (current + 1) % photos.length;
        img.src = photos[current];
        img.classList.remove('flipping-out');
        img.classList.add('flipping-in');
      }, 175);

      setTimeout(() => {
        img.classList.remove('flipping-in');
      }, 350);
    });
  }
</script>
