---
interface Props {
  title: string;
  date: Date;
  tags?: string[];
  categories?: string[];
  author?: string;
  venue?: string;
  year?: number;
  thumb?: string;
  slug: string;
}

const { title, date, tags = [], author, venue, year, thumb, slug } = Astro.props;
---

<article class="card border-notes hover-glow-notes overflow-hidden group flex flex-col">
  <a href={`/notes/${slug}`} class="block shrink-0">
    {thumb ? (
      <div class="overflow-hidden" style="height: 100px;">
        <img
          src={thumb}
          alt={title}
          class="w-full h-full object-cover transition-transform duration-300 group-hover:scale-105"
        />
      </div>
    ) : (
      <div class="flex items-center justify-center" style="height: 100px; background: rgba(255,77,107,0.07);">
        <span style="font-size: 2rem;">📄</span>
      </div>
    )}
  </a>

  <div class="p-3 flex flex-col flex-1">
    <a href={`/notes/${slug}`} class="block mb-1">
      <h3 class="font-semibold text-xs leading-snug transition-colors group-hover:text-pink-300" style="color: #ede9f8;">
        {title}
      </h3>
    </a>

    <p class="text-xs mb-2" style="color: #9e99b0; font-size: 0.7rem;">
      {author && <span>{author}</span>}
      {venue && <span> · {venue}</span>}
      {year && <span> · {year}</span>}
    </p>

    {tags.length > 0 && (
      <div class="flex flex-wrap gap-1 mt-auto">
        {tags.slice(0, 2).map((tag) => (
          <span class="tag tag-notes" style="font-size: 0.62rem; padding: 1px 6px;">{tag}</span>
        ))}
      </div>
    )}
  </div>
</article>
